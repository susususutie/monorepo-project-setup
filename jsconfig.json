{
  "compilerOptions": {
    "jsx": "react-jsx",
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "baseUrl": ".",
    "paths": {
      "@foundation": ["packages/foundation/src/index.js"],
      "@foundation/*": ["packages/foundation/src/*"],
      "@business-core": ["packages/business-core/src/index.js"],
      "@business-core/*": ["packages/business-core/src/*"],
      "@assets/*": ["packages/assets/src/*"],
      "@app-iam/*": ["apps/app-iam/src/*"]
    }
  },
  "include": [
    "apps/*/src",
    "packages/*/src",
    "apps/*/vite.config.js",
    "packages/*/vite.config.js"
  ],
  "exclude": [
    "dist",
    "build",
    "node_modules",
    "apps/*/dist",
    "apps/*/build",
    "apps/*/node_modules",
    "packages/*/dist",
    "packages/*/build",
    "packages/*/node_modules"
  ]
}
